  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.7",
    "alpinejs": "^3.14.9",
    "daisyui": "^5.0.38",
    "htmx.org": "^2.0.4",
    "rolldown": "^1.0.0-beta.9",
    "tailwindcss": "^4.1.7"
  }
}
